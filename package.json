{
  "name": "github-release-subscription-api",
  "version": "1.0.0",
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:notification": "tsc -p apps/notification/tsconfig.app.json",
    "build:tracker": "tsc -p apps/tracker/tsconfig.app.json",
    "build:github": "tsc -p apps/github/tsconfig.app.json",
    "start": "tsx src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "start:prod": "node dist/src/main.js",
    "start:notification": "tsx apps/notification/src/main.ts",
    "start:prod:notification": "node dist/apps/notification/src/main.js",
    "start:tracker": "tsx apps/tracker/src/main.ts",
    "start:prod:tracker": "node dist/apps/tracker/src/main.js",
    "start:github": "tsx apps/github/src/main.ts",
    "start:prod:github": "node dist/apps/github/src/main.js",
    "format": "prettier --write .",
    "format:diff": "prettier --list-different . --ignore-unknown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate:dev": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:check": "npx prisma migrate diff --exit-code --from-config-datasource --to-schema=./prisma/schema.prisma",
    "test:unit": "jest --selectProjects unit",
    "test:int": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects integration --runInBand",
    "test:e2e": "playwright test",
    "test:cov": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "axios": "^1.15.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ms": "^2.1.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@octokit/types": "^16.0.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nock": "^14.0.15",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
